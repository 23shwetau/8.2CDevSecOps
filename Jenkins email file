pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/23shwetau/8.2CDevSecOps.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Run Tests') {
            steps {
                bat 'npm test || exit /b 0'
            }
        }

        stage('Generate Coverage Report') {
            steps {
                bat 'npm run coverage || exit /b 0'
            }
        }

        stage('NPM Audit (Security Scan)') {
            steps {
                bat 'npm audit || exit /b 0'
            }
        }

        stage('Send Email Notification') {
            steps {
                emailext (
                    subject: "Build Result: ${currentBuild.currentResult}",
                    body: "Build ${currentBuild.currentResult}. Check Jenkins for details.",
                    to: "23shwetau@gmail.com",
                    attachLog: true
                )
            }
        }
    }
}
